# Example environment variables for local adaptation

# Optional path overrides used by the current codebase
AUTO_TRADER_DATA_DIR=/path/to/.trading-data
AUTO_TRADER_DB_PATH=/path/to/.trading-data/trading.db
AUTO_TRADER_TRADING_MD=/path/to/trading.md

# Spot mode control
AUTO_TRADE_MODE=paper

# Telegram integration
TELEGRAM_TRADE_CHAT_ID=123456789
TELEGRAM_TOKEN_FILE=/path/to/telegram.txt

# Tiny live pilot controls (examples)
AUTO_TRADER_TINY_LIVE_PILOT_ENABLED=1
AUTO_TRADER_TINY_LIVE_PILOT_ALLOW_LIVE=1
AUTO_TRADER_TINY_LIVE_PILOT_SYMBOLS=PYTH,RAY,JUP,WIF
